# remove.bg API Key
# 获取方式：https://www.remove.bg/api
RB_API_KEY=your_api_key_here

# Google OAuth
# 获取方式：https://console.cloud.google.com/apis/credentials
# 授权重定向 URI: https://www.bg-remover.site/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth
# 生成方式：openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://www.bg-remover.site
